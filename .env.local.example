# Anthropic API
ANTHROPIC_API_KEY="sk-ant-..."

# Supabase — pull from `supabase projects api-keys --project-ref <ref>`
NEXT_PUBLIC_SUPABASE_URL="https://<ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# SERVER ONLY — bypasses Row-Level Security
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# Deepgram — streaming transcription for the voice-log feature.
# Key needs Admin or Member scope so it can mint short-lived tokens via
# /v1/auth/grant. The browser never sees this key — only 30s JWTs.
DEEPGRAM_API_KEY="..."

# Google Vertex AI — Gemini 2.5 Flash for medication-label photo
# extraction. Use the BAA-eligible Vertex tier, NOT the consumer Gemini
# API (which trains on inputs by default).
#
# CREDENTIALS_JSON is a base64-encoded service-account JSON. Long-lived
# SA keys for v1; post-launch we migrate to OIDC + Workload Identity
# Federation per docs/status.md.
GOOGLE_VERTEX_AI_PROJECT_ID=""
GOOGLE_VERTEX_AI_LOCATION="us-central1"
GOOGLE_VERTEX_AI_CREDENTIALS_JSON=""
