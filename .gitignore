# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — ignore local secrets, commit examples
.env*.local
.env
!.env*.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# capacitor
/ios/App/Pods/
/ios/App/Podfile.lock
/ios/App/build/
/ios/DerivedData/
/android/.gradle/
/android/build/
/android/app/build/
/android/local.properties
/android/.idea/
/android/app/release/
/android/captures/
*.iml

# supabase
/supabase/.branches
/supabase/.temp

# claude / agent caches — track config + hooks + rules; ignore local state
.claude/*
!.claude/settings.json
!.claude/hooks/
!.claude/rules/

# self-signed dev certificates (generated, not committed)
/certificates/

# youtube-study research output (local only — re-fetch via youtube-study skill if needed)
/youtube-study/

