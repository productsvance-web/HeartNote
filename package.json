{
  "name": "heartnote",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 0.0.0.0 -p 3001 --experimental-https --experimental-https-key ./certificates/localhost-key.pem --experimental-https-cert ./certificates/localhost.pem",
    "prebuild": "node --experimental-strip-types scripts/validate-rxnorm-index.ts",
    "build": "next build",
    "start": "next start -H 0.0.0.0 -p 3001",
    "lint": "eslint",
    "test:rxnorm": "node --test --experimental-strip-types src/lib/medications/rxnorm-search.test.ts",
    "test:rxnorm:integration": "node --test --experimental-strip-types src/lib/medications/rxnorm.test.ts",
    "test:rxnorm-ndc": "node --test --experimental-strip-types src/lib/medications/rxnorm-ndc.test.ts",
    "test:scan-enrich": "node --test --experimental-strip-types src/lib/medications/scan/enrich.test.ts",
    "test:scan-prompt": "node --test --experimental-strip-types src/lib/medications/scan/prompt.test.ts",
    "test:scan-payload": "node --test --experimental-strip-types src/app/me/medications/scan/extracted-to-payload.test.ts",
    "rxnorm:refresh": "node --experimental-strip-types scripts/refresh-rxnorm-index.ts",
    "db:types": "supabase gen types typescript --linked 2>/dev/null | grep -v '^A new version\\|^We recommend\\|^Initialising' > src/lib/supabase/types.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@base-ui/react": "^1.4.1",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/core": "^8.3.1",
    "@google-cloud/vertexai": "^1.12.0",
    "@ionic/pwa-elements": "^3.4.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.104.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.11.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "shadcn": "^4.5.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
